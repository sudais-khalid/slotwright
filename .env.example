# Copy to .env and fill in real values. .env is gitignored — never commit it.

# MongoDB root credentials (used by the mongo container and the backend's connection string)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change-me-to-a-strong-password

# Comma-separated list of origins allowed to call the backend API directly.
# The bundled frontend talks to the backend through nginx's same-origin proxy,
# so this only matters if something else calls the API from a browser.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
